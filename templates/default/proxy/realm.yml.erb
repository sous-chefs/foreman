---
# Manage joining realms e.g. FreeIPA
:enabled: <%= @module_enabled %>

# Available providers:
#   freeipa
:realm_provider: <%= @config[:provider] %>

# Authentication for Kerberos-based Realms
:realm_keytab: <%= @config[:keytab] %>
:realm_principal: <%= @config[:principal] %>

# FreeIPA specific settings
# Remove from DNS when deleting the FreeIPA entry
:freeipa_remove_dns: <%= @config[:freeipa_remove_dns] %>
