<VirtualHost *:<%= @params[:server_port] || @params[:apache][:listen_ports].first %>>
  ServerName <%= @params[:server_name] %>
  <% if @params[:server_aliases] -%>
  ServerAlias <%= @params[:server_aliases].join " " %>
  <% end -%>

  <% if @params[:foreman][:ssl_enabled] -%>
  <IfModule mod_ssl.c>
    SSLEngine on
    SSLCACertificateFile <%= @params[:foreman][:ssl][:ca_file] %>
    SSLCertificateFile <%= @params[:foreman][:ssl][:cert_file] %>
    SSLCertificateKeyFile <%= @params[:foreman][:ssl][:cert_key_file] %>
  </IfModule>
  <% end -%>

  DocumentRoot <%= @params[:docroot] %>

  RailsBaseURI /
  RailsEnv <%= @params[:foreman][:environment] %>

  <Directory <%= @params[:docroot] %>>
    Options FollowSymLinks
    AllowOverride None
  <% if @params[:apache][:version] == '2.4' -%>
    Require all granted
  <% else -%>
    Order allow,deny
    Allow from all
  <% end -%>
  </Directory>

  LogLevel info

  <%- if @params[:apache][:version] == '2.4' -%>
  LogLevel info rewrite:trace1
  <%- else -%>
  LogLevel info
  RewriteLog <%= @params[:apache][:log_dir] %>/<%= @application_name %>-rewrite.log
  RewriteLogLevel 0
  <%- end -%>

  ErrorLog <%= @params[:apache][:log_dir] %>/<%= @params[:name] %>-error.log
  CustomLog <%= @params[:apache][:log_dir] %>/<%= @params[:name] %>-access.log combined

  RewriteEngine On
  RewriteCond %{HTTP_HOST}   !^<%= @params[:server_name] %> [NC]
  RewriteCond %{HTTP_HOST}   !^$
  RewriteRule ^/(.*)$        http://<%= @params[:server_name] %>/$1 [L,R=301]

  RewriteCond %{DOCUMENT_ROOT}/system/maintenance.html -f
  RewriteCond %{SCRIPT_FILENAME} !maintenance.html
  RewriteRule ^.*$ /system/maintenance.html [L]

  <% if @params[:foreman][:passenger][:path] -%>
  PassengerAppRoot <%= @params[:foreman][:passenger][:path] %>
  <% end -%>
  <% if @params[:foreman][:environment] -%>
  PassengerAppEnv <%= @params[:foreman][:environment] %>
  <% end -%>
  <% if @params[:foreman][:passenger][:ruby] -%>
  PassengerRuby <%= @params[:foreman][:passenger][:ruby] %>
  <% end -%>
  <% if @params[:foreman][:passenger][:min_instances] -%>
  PassengerMinInstances <%= @params[:foreman][:passenger][:min_instances] %>
  <% end -%>
  <% if @params[:foreman][:passenger][:start_timeout] -%>
  PassengerStartTimeout <%= @params[:foreman][:passenger][:start_timeout] %>
  <% end -%>
  <% if @params[:foreman][:passenger][:pre_start] -%>
  PassengerPreStart <%= @params[:foreman][:passenger][:pre_start] %>
  <% end -%>
</VirtualHost>
