---
# You must restart the Rack server after changing either of these values
# because they are cached at startup.
#
:unattended: <%= @settings[:unattended] %>
:puppetconfdir: <%= @settings[:puppetconfdir] %>
:login: <%= @settings[:authentication] %>
:require_ssl: <%= @ssl_enabled %>
:locations_enabled: <%= @settings[:locations_enabled] %>
:organizations_enabled: <%= @settings[:organizations_enabled] %>

# The following values are used for providing default settings during db migrate
:oauth_active: <%= @settings[:oauth_active] %>
:oauth_map_users: <%= @settings[:oauth_map_users] %>
:oauth_consumer_key: <%= @settings[:oauth_consumer_key] %>
:oauth_consumer_secret: <%= @settings[:oauth_consumer_secret] %>

# Websockets
:websockets_encrypt: <%= @settings[:websockets_encrypt] ? 'on' : 'off' %>
:websockets_ssl_key: <%= @settings[:websockets_ssl_key] %>
:websockets_ssl_cert: <%= @settings[:websockets_ssl_cert] %>

:ssl_ca_file: <%= @ssl[:ca_file] %>
:ssl_certificate: <%= @ssl[:cert_file] %>
:ssl_priv_key: <%= @ssl[:cert_key_file] %>
