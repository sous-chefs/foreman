---
:settings_directory: <%= @proxy[:settings_directory] %>

# SSL Setup
<% ssl = @proxy[:ssl_enabled] -%>
<% http = @proxy[:http_enabled] -%>

# if enabled, all communication would be verfied via SSL
# NOTE that both certificates need to be signed by the same CA in order for this to work
# see http://theforeman.org/projects/smart-proxy/wiki/SSL for more information
<% if ssl && @proxy[:ssl][:ca_file] -%>
:ssl_ca_file: <%= @proxy[:ssl][:ca_file] %>
<% else -%>
#:ssl_ca_file: ssl/certs/ca.pem
<% end -%>
<% if ssl && @proxy[:ssl][:cert_file] -%>
:ssl_certificate: <%= @proxy[:ssl][:cert_file] %>
<% else -%>
#:ssl_certificate: ssl/certs/fqdn.pem
<% end -%>
<% if ssl && @proxy[:ssl][:cert_key_file] -%>
:ssl_private_key: <%= @proxy[:ssl][:cert_key_file] %>
<% else -%>
#:ssl_private_key: ssl/private_keys/fqdn.key
<% end -%>

# the hosts which the proxy accepts connections from
# commenting the following lines would mean every verified SSL connection allowed
<% if thosts = @proxy[:trusted_hosts] and thosts.any? -%>
:trusted_hosts:
<% thosts.each do |h| -%>
<%= "  - #{h}" %>
<% end -%>
<% else -%>
#:trusted_hosts:
#- foreman.prod.domain
#- foreman.dev.domain
<% end -%>

# Endpoint for reverse communication
:foreman_url: <%= @proxy[:foreman_url] %>

# SSL settings for client authentication against Foreman. If undefined, the values
# from general SSL options are used instead. Mainly useful when Foreman uses
# different certificates for its web UI and for smart-proxy requests.
<% unless [nil, :undefined, :undef].include?(@proxy[:ssl][:foreman_ssl_ca]) -%>
:foreman_ssl_ca: <%= @proxy[:ssl][:foreman_ssl_ca] %>
<% else -%>
#:foreman_ssl_ca: ssl/certs/ca.pem
<% end -%>
<% unless [nil, :undefined, :undef].include?(@proxy[:ssl][:foreman_ssl_cert]) -%>
:foreman_ssl_cert: <%= @proxy[:ssl][:foreman_ssl_cert] %>
<% else -%>
#:foreman_ssl_cert: ssl/certs/fqdn.pem
<% end -%>
<% unless [nil, :undefined, :undef].include?(@proxy[:ssl][:foreman_ssl_key]) -%>
:foreman_ssl_key: <%= @proxy[:ssl][:foreman_ssl_key] %>
<% else -%>
#:foreman_ssl_key: ssl/private_keys/fqdn.pem
<% end -%>

# by default smart_proxy runs in the foreground. To enable running as a daemon, uncomment 'daemon' setting
:daemon: <%= @proxy[:daemon] %>
# Only used when 'daemon' is set to true.
# Uncomment and modify if you want to change the default pid file '/var/run/foreman-proxy/foreman-proxy.pid'
#:daemon_pid: /var/run/foreman-proxy/foreman-proxy.pid

# HTTP ports configuration
# http is disabled by default. To enable, uncomment 'http_port' setting
# https is enabled if certificate, CA certificate, and private key are present in locations specifed by
# ssl_certificate, ssl_ca_file, and ssl_private_key correspondingly
# default values for https_port is 8443
<%= '#' unless ssl -%>:https_port: <%= @proxy[:https_port] %>
<%= '#' unless http -%>:http_port: <%= @proxy[:http_port] %>

# shared options for virsh DNS/DHCP provider
:virsh_network: <%= @proxy[:virsh_network] %>

# Where our proxy log files are stored
# filename or STDOUT
:log_file: <%= @proxy[:log_file] %>
# valid options are
# WARN, DEBUG, Error, Fatal, INFO, UNKNOWN
:log_level: <%= @proxy[:log_level] %>
